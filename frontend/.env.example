# API URL (uses Vite proxy in dev — see vite.config.ts)
VITE_API_URL=/api

# Optional: backend origin for Vite dev proxy
# If your backend runs on a different host/port, set this (example: http://localhost:5000)
VITE_API_PROXY_TARGET=http://localhost:5000

# Google OAuth
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Google OAuth Allowed Origins for local development
# Add these origins to Google Cloud Console: APIs & Services → Credentials → OAuth 2.0 Client ID → Authorized JavaScript Origins
VITE_GOOGLE_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
